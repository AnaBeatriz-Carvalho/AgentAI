# Exemplo de .env para o AgentAI
# Este projeto usa um LLM local via API OpenAI-compatível (ex.: LM Studio).

# Endpoint do servidor (padrão do LM Studio):
LOCAL_LLM_BASE_URL=http://localhost:1234/v1

# Em servidores locais, qualquer valor costuma funcionar (o LM Studio ignora),
# mas o SDK exige um campo api_key.
LOCAL_LLM_API_KEY=lm-studio

# Nome do modelo como exposto pelo servidor local.
# Recomendado: Mistral 7B Instruct
LOCAL_LLM_MODEL=mistralai/mistral-7b-instruct-v0.3
